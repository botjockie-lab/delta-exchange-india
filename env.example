# Delta Exchange API Credentials
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here
DELTA_BASE_URL=https://api.india.delta.exchange

# Trading Parameters
TAKE_PROFIT_PERCENT=30
STOP_LOSS_PERCENT=5
POSITION_SIZE=1
MAX_POSITIONS=4
OPTION_TYPE=BOTH
MIN_OPTION_PRICE=50
MIN_RR=2.0
TARGET_EXPIRY=DD-MM-YYYY

# Technical Indicators
ADX_THRESHOLD=20
USE_ADX_FILTER=False
ADX_PERIOD=14
BB_PERIOD=10
BB_STD_DEV=3.0
EMA_PERIOD=200
USE_EMA_FILTER=False

# Strategy Settings
CYCLE_INTERVAL=60
MOCK_MODE=False
RESOLUTION=15m
SIGNAL_EXPIRY_BARS=20
